{
  "name": "@bedlamlabs/dixie",
  "version": "4.0.0",
  "description": "CLI browser — render web pages, query DOM, run tests, all without a real browser",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dixie": "./dist/dixie.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "build:cli": "esbuild bin/dixie.ts --bundle --platform=node --format=esm --outfile=dist/dixie.mjs --external:esbuild --external:js-yaml --banner:js='#!/usr/bin/env node' && chmod +x dist/dixie.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["browser", "cli", "dom", "testing", "agents", "headless", "render"],
  "repository": {
    "type": "git",
    "url": "https://github.com/bedlamlabs/dixie"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "js-yaml": "^4.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
